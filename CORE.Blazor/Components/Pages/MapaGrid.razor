@using CORE.Blazor.Models

<div class="mapa-wrapper">
    <div class="mapa-header">
        <span class="mapa-title">🗺 Mapa do Mundo</span>
    </div>
    <div class="mapa-grid">
        @for (int y = 0; y < TamanhoY; y++)
        {
            <div class="mapa-row">
                @for (int x = 0; x < TamanhoX; x++)
                {
                    var regiao = ObterRegiao(x, y);
                    var classe = ObterClasseTerreno(regiao);
                    <div class="celula @classe" title="@ObterTooltip(regiao, x, y)">
                        <span class="celula-icone">@ObterIcone(regiao)</span>
                        @if (regiao is not null)
                        {
                            <span class="celula-civ">@regiao.CivilizacaoNome[..Math.Min(3, regiao.CivilizacaoNome.Length)]</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .mapa-wrapper {
        background: rgba(8, 6, 4, 0.95);
        border: 1px solid rgba(201, 168, 76, 0.3);
        border-radius: 4px;
        overflow: hidden;
        display: inline-block;
    }

    .mapa-header {
        padding: 0.6rem 1rem;
        background: rgba(201, 168, 76, 0.08);
        border-bottom: 1px solid rgba(201, 168, 76, 0.2);
    }

    .mapa-title {
        font-family: 'Cinzel', serif;
        color: #c9a84c;
        font-size: 0.85rem;
        letter-spacing: 0.1em;
    }

    .mapa-grid {
        padding: 6px;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .mapa-row {
        display: flex;
        gap: 2px;
    }

    .celula {
        width: 48px;
        height: 48px;
        border-radius: 3px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: default;
        transition: transform 0.15s, box-shadow 0.15s;
        position: relative;
        border: 1px solid rgba(0,0,0,0.4);
    }

        .celula:hover {
            transform: scale(1.1);
            z-index: 10;
            box-shadow: 0 4px 16px rgba(0,0,0,0.6);
        }

    .celula-icone {
        font-size: 1.2rem;
        line-height: 1;
    }

    .celula-civ {
        font-family: 'Cinzel', serif;
        font-size: 0.45rem;
        font-weight: 700;
        color: #fff;
        background: rgba(0,0,0,0.65);
        padding: 1px 3px;
        border-radius: 2px;
        margin-top: 2px;
        letter-spacing: 0.05em;
        text-shadow: 0 1px 2px rgba(0,0,0,0.8);
    }

    .terreno-vazio {
        background: #1a1a2e;
        border-color: #2a2a3e;
    }

    .terreno-planicie {
        background: linear-gradient(135deg, #2d5a1b, #3d7a25);
        border-color: #4a8a30;
    }

    .terreno-floresta {
        background: linear-gradient(135deg, #1a3d10, #2a5518);
        border-color: #1a3d10;
    }

    .terreno-montanha {
        background: linear-gradient(135deg, #3a3a4a, #4a4a5a);
        border-color: #5a5a6a;
    }

    .terreno-rio {
        background: linear-gradient(135deg, #1a3a6a, #2a5a9a);
        border-color: #3a7aba;
    }

    .terreno-deserto {
        background: linear-gradient(135deg, #6a5020, #8a7030);
        border-color: #aa9040;
    }
</style>

@code {
    [Parameter] public List<RegiaoModel> Regioes { get; set; } = new();
    [Parameter] public int TamanhoX { get; set; } = 10;
    [Parameter] public int TamanhoY { get; set; } = 10;

    private RegiaoModel? ObterRegiao(int x, int y)
        => Regioes.FirstOrDefault(r => r.X == x && r.Y == y);

    private string ObterClasseTerreno(RegiaoModel? r)
    {
        if (r is null) return "terreno-vazio";
        return r.Terreno switch
        {
            "Planicie" => "terreno-planicie",
            "Floresta" => "terreno-floresta",
            "Montanha" => "terreno-montanha",
            "Rio" => "terreno-rio",
            "Deserto" => "terreno-deserto",
            _ => "terreno-vazio"
        };
    }

    private string ObterIcone(RegiaoModel? r)
    {
        if (r is null) return "·";
        return r.Terreno switch
        {
            "Planicie" => "🌾",
            "Floresta" => "🌲",
            "Montanha" => "⛰️",
            "Rio" => "🏞️",
            "Deserto" => "🏜️",
            _ => "·"
        };
    }

    private string ObterTooltip(RegiaoModel? r, int x, int y)
    {
        if (r is null) return $"({x},{y}) Território desocupado";
        return $"{r.Nome} — {r.Terreno} — {r.CivilizacaoNome}";
    }
}
